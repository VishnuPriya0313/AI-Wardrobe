# AI provider: use openai for deployment, ollama for local experiments.
AI_PROVIDER=openai
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llava
OLLAMA_MATCH_MODEL=llama3.2:3b

PORT=8080
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://your-frontend-domain.pages.dev

APP_S3_ENABLED=true
APP_S3_BUCKET=your-wardrobe-bucket
APP_S3_REGION=auto
APP_S3_KEY_PREFIX=wardrobe-uploads
APP_S3_PUBLIC_BASE_URL=
APP_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

AWS_ACCESS_KEY_ID=replace_with_access_key
AWS_SECRET_ACCESS_KEY=replace_with_secret_key
